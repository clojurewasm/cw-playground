{:deps {:aliases [:dev]}
 :nrepl {:port 9630}
 :dev-http {3000 "resources/public"}
 :js-options {:js-package-dirs ["node_modules"]}
 :builds
 {:app
  {:target :browser
   :output-dir "resources/public/js"
   :asset-path "/js"
   :modules {:main {:entries [playground.core] :init-fn playground.core/init}}
   :compiler-options {:output-feature-set :es2020
                      :infer-externs :auto}}}}
